# このスクリプトは https://sspai.com/post/66894 より引用
# remove yadm readme
if [[ ! -f "${YADM_HOOK_REPO}/info/sparse-checkout" ]]; then
  yadm gitconfig core.sparseCheckout true
  cat << EOF > "${YADM_HOOK_REPO}/info/sparse-checkout"
# Generated by $0
/*
!.github
!.vscode
!.editorconfig
!LICENSE
!README.md
!setup_win.ps1
!setup.sh
EOF
  yadm checkout --quiet
fi